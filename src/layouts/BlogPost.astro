---
import Reading from './Reading.astro';

interface Props {
  title: string;
  subtitle?: string;
  date: string;
  categories?: string;
  tags?: string[];
}

const { title, subtitle, date, categories, tags } = Astro.props;
---

<Reading
  title={title}
  subtitle={subtitle}
  date={date}
  categories={categories}
  tags={tags}
  backHref="/blog"
  backLabel="← 게시판으로"
  screenLabel="READING"
  activeId="blog"
  footerHint="[Q/ESC] 목록으로  ·  [1] 게시판  [4] 홈"
>
  <slot />
</Reading>
