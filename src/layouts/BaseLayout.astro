---
import '../styles/global.css';
import '../styles/crt.css';
import BBSFrame from '../components/BBSFrame.astro';

interface Props {
  title: string;
  description?: string;
  screenLabel?: string;
  footerHint?: string;
  activeId?: 'home' | 'blog' | 'projects' | 'about' | 'post' | 'other';
  padded?: boolean;
}

const {
  title,
  description = '슬비스가 운영하는 박슬기의 블로그',
  screenLabel = '',
  footerHint,
  activeId,
  padded = true,
} = Astro.props;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/slvis-logo.svg" />
    <title>{title}</title>
  </head>
  <body>
    <div class="bbs-root">
      <div class="bbs-shell">
        <BBSFrame screenLabel={screenLabel} footerHint={footerHint} activeId={activeId}>
          <main class:list={['bbs-main', padded && 'is-padded']}>
            <slot />
          </main>
        </BBSFrame>
      </div>
    </div>
    <div class="crt-overlay" aria-hidden="true"></div>
  </body>
</html>

<style is:global>
  .bbs-root {
    min-height: 100vh;
    position: relative;
    z-index: 1;
    padding: 20px 28px;
  }
  .bbs-shell {
    max-width: 1200px;
    margin: 0 auto;
    min-height: calc(100vh - 40px);
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(127, 255, 155, 0.15);
    padding: 18px 26px;
    background: transparent;
  }
  .bbs-main {
    flex: 1;
    min-height: 0;
    display: flex;
    flex-direction: column;
  }
  .bbs-main.is-padded {
    padding: 14px 0 4px;
  }
  @media (max-width: 768px) {
    .bbs-root {
      padding: 8px;
    }
    .bbs-shell {
      padding: 12px 14px;
      min-height: calc(100vh - 16px);
    }
  }
</style>
