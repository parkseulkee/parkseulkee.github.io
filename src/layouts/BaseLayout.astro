---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '슬비스가 운영하는 박슬기의 블로그' } = Astro.props;
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/slvis-logo.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col hud-scanline">
    <!-- Animated Background -->
    <div id="bg-container" style="position:fixed;inset:0;z-index:0;overflow:hidden;background:#00050A;">
      <canvas id="bg-stars" style="position:absolute;inset:0;width:100%;height:100%;"></canvas>
      <canvas id="bg-nebula" style="position:absolute;inset:0;width:100%;height:100%;"></canvas>
    </div>

    <!-- Navigation -->
    <nav class="sticky top-0 z-50 border-b border-dark-border" style="background: rgba(0, 5, 10, 0.85); backdrop-filter: blur(12px);">
      <div class="max-w-4xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 sm:gap-3 group shrink-0">
          <img src="/slvis-logo.svg" alt="SLVIS" class="w-7 h-7 sm:w-8 sm:h-8 group-hover:drop-shadow-[0_0_8px_rgba(0,212,255,0.6)] transition-all" />
          <span class="hidden sm:inline font-hud font-bold text-lg glow-text tracking-wider text-primary">SLVIS</span>
        </a>
        {!isHome && (
          <div class="flex items-center gap-4 sm:gap-8">
            <a href="/blog" class:list={["hud-nav-link", "!tracking-normal", "sm:!tracking-widest", pathname.startsWith('/blog') && "active"]}>Blog</a>
            <a href="/projects" class:list={["hud-nav-link", "!tracking-normal", "sm:!tracking-widest", pathname.startsWith('/projects') && "active"]}>Projects</a>
<a href="/about" class:list={["hud-nav-link", "!tracking-normal", "sm:!tracking-widest", pathname.startsWith('/about') && "active"]}>About</a>
          </div>
        )}
      </div>
    </nav>

    <main class="flex-1 relative z-10">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-dark-border mt-20 relative z-10">
      <div class="max-w-4xl mx-auto px-6 py-8 text-center text-sm text-hud-dim">
        <p class="flex items-center justify-center gap-2 font-mono">
          <img src="/slvis-logo.svg" alt="" class="w-4 h-4 opacity-50" />
          Operated by <span class="text-primary glow-text-sm font-hud text-xs tracking-wider">SLVIS</span> · © {new Date().getFullYear()} Seulkee Park
        </p>
      </div>
    </footer>

    <!-- Background Animation Script -->
    <script>
      function initBackground() {
        const dpr = window.devicePixelRatio || 1;

        // === STARS (dots) ===
        const starsCanvas = document.getElementById('bg-stars') as HTMLCanvasElement;
        const starsCtx = starsCanvas.getContext('2d')!;

        // === NEBULA (puffs) ===
        const nebulaCanvas = document.getElementById('bg-nebula') as HTMLCanvasElement;
        const nebulaCtx = nebulaCanvas.getContext('2d')!;

        let width = window.innerWidth;
        let height = window.innerHeight;

        function resize() {
          width = window.innerWidth;
          height = window.innerHeight;
          starsCanvas.width = width * dpr;
          starsCanvas.height = height * dpr;
          starsCtx.scale(dpr, dpr);
          nebulaCanvas.width = width * dpr;
          nebulaCanvas.height = height * dpr;
          nebulaCtx.scale(dpr, dpr);
          generateStars();
          generatePuffs();
        }

        // Stars
        interface Star {
          x: number; y: number; size: number; alpha: number;
          twinkleSpeed: number; twinkleOffset: number;
        }
        let stars: Star[] = [];

        function generateStars() {
          const count = Math.floor((width * height) / 4000);
          stars = [];
          for (let i = 0; i < count; i++) {
            stars.push({
              x: Math.random() * width,
              y: Math.random() * height,
              size: Math.random() * 1.2 + 0.2,
              alpha: Math.random() * 0.4 + 0.1,
              twinkleSpeed: Math.random() * 0.003 + 0.001,
              twinkleOffset: Math.random() * Math.PI * 2,
            });
          }
        }

        function drawStars(time: number) {
          starsCtx.clearRect(0, 0, width, height);
          for (const star of stars) {
            const flicker = Math.sin(time * star.twinkleSpeed + star.twinkleOffset);
            const alpha = star.alpha + flicker * 0.1;
            starsCtx.beginPath();
            starsCtx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
            starsCtx.fillStyle = `rgba(180, 220, 255, ${Math.max(0.05, Math.min(1, alpha))})`;
            starsCtx.fill();
          }
        }

        // Nebula puffs
        interface Puff {
          x: number; y: number; radius: number;
          vx: number; vy: number;
          hue: number; alpha: number;
        }
        let puffs: Puff[] = [];

        function generatePuffs() {
          puffs = [];
          const count = 8;
          for (let i = 0; i < count; i++) {
            puffs.push({
              x: Math.random() * width,
              y: Math.random() * height,
              radius: Math.random() * 400 + 250,
              vx: (Math.random() - 0.5) * 0.1,
              vy: (Math.random() - 0.5) * 0.06,
              hue: 175 + Math.random() * 30, // cyan-teal range
              alpha: Math.random() * 0.12 + 0.14,
            });
          }
        }

        function drawNebula() {
          nebulaCtx.clearRect(0, 0, width, height);
          for (const puff of puffs) {
            // Move
            puff.x += puff.vx;
            puff.y += puff.vy;
            // Wrap
            if (puff.x < -puff.radius) puff.x = width + puff.radius;
            if (puff.x > width + puff.radius) puff.x = -puff.radius;
            if (puff.y < -puff.radius) puff.y = height + puff.radius;
            if (puff.y > height + puff.radius) puff.y = -puff.radius;

            const gradient = nebulaCtx.createRadialGradient(
              puff.x, puff.y, 0,
              puff.x, puff.y, puff.radius
            );
            gradient.addColorStop(0, `hsla(${puff.hue}, 80%, 30%, ${puff.alpha})`);
            gradient.addColorStop(0.3, `hsla(${puff.hue}, 60%, 20%, ${puff.alpha * 0.7})`);
            gradient.addColorStop(0.6, `hsla(${puff.hue}, 40%, 12%, ${puff.alpha * 0.3})`);
            gradient.addColorStop(1, `hsla(${puff.hue}, 30%, 5%, 0)`);

            nebulaCtx.beginPath();
            nebulaCtx.arc(puff.x, puff.y, puff.radius, 0, Math.PI * 2);
            nebulaCtx.fillStyle = gradient;
            nebulaCtx.fill();
          }
        }

        // Animation loop
        function animate(time: number) {
          drawStars(time);
          drawNebula();
          requestAnimationFrame(animate);
        }

        resize();
        window.addEventListener('resize', resize);
        requestAnimationFrame(animate);
      }

      // Run on page load and navigation
      document.addEventListener('astro:page-load', initBackground);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initBackground);
      } else {
        initBackground();
      }
    </script>
  </body>
</html>
