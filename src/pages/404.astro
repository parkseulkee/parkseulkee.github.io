---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tensi from '../components/Tensi.tsx';
---

<BaseLayout
  title="404 — SLVIS"
  screenLabel="ERROR 404"
  activeId="other"
  footerHint="[4] 홈으로  ·  존재하지 않는 경로"
>
  <section class="e404">
    <Tensi client:visible size={180} />
    <pre class="ascii amber e404-code">
{`┌───────────────┐
│  ERROR  404   │
└───────────────┘`}
    </pre>
    <p class="screen sans e404-msg">
      앗, 이 페이지는 찾을 수 없어요.<br />
      제가 아직 정리하지 못한 곳인 것 같아요<span class="cursor-blink"></span>
    </p>
    <div class="e404-actions">
      <a href="/" class="btn-bbs"><span class="key">[4]</span>홈으로</a>
      <a href="/blog" class="btn-bbs"><span class="key">[1]</span>게시판</a>
    </div>
  </section>
</BaseLayout>

<style>
  .e404 {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 20px;
    padding: 40px 0;
    text-align: center;
  }
  .e404-code {
    font-size: 14px;
    line-height: 1.3;
    margin: 8px 0 0;
  }
  .e404-msg {
    font-size: 15px;
    line-height: 1.8;
    max-width: 420px;
    margin: 0;
  }
  .e404-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
</style>
