---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tensi from '../components/Tensi.tsx';
import SectionRule from '../components/SectionRule.astro';
import { ABOUT } from '../content/about';
---

<BaseLayout
  title="About — SLVIS"
  screenLabel="ABOUT"
  activeId="about"
  footerHint="[1] 게시판  [2] 프로젝트  [3] 소개  [4] 홈"
>
  <section class="about-grid">
    <!-- LEFT: sticky profile -->
    <aside class="about-profile">
      <Tensi client:visible size={180} />
      <h1 class="screen sans about-name">{ABOUT.name}</h1>
      <p class="amber about-role">{ABOUT.role}</p>
      <p class="sans about-intro">{ABOUT.intro}</p>

      <div class="about-rule"><SectionRule title="CONTACT" width={32} as="h2" /></div>
      <ul class="about-contact mono">
        <li>
          <span class="phos-dim">✉</span>
          <a
            href={`mailto:${ABOUT.email}`}
            class="hoverable screen"
            data-label="이메일"
          >
            {ABOUT.email}
          </a>
        </li>
        <li>
          <span class="phos-dim">▸</span>
          <a href={ABOUT.github} target="_blank" rel="noopener" class="hoverable screen">
            {ABOUT.githubLabel}
          </a>
        </li>
        <li>
          <span class="phos-dim">▸</span>
          <a href={ABOUT.linkedin} target="_blank" rel="noopener" class="hoverable screen">
            {ABOUT.linkedinLabel}
          </a>
        </li>
      </ul>

      <div class="about-rule"><SectionRule title="HIGHLIGHTS" width={32} as="h2" /></div>
      <ul class="about-highlights mono">
        {
          ABOUT.highlights.map((h) => (
            <li>
              <span class="phos-dim about-hl-label">{h.label}</span>
              <span class="amber about-hl-value">{h.value}</span>
              <span class="phos-dim about-hl-desc">{h.desc}</span>
            </li>
          ))
        }
      </ul>
    </aside>

    <!-- RIGHT: sections -->
    <div class="about-body bbs-scroll">
      <div class="bbs-section">
        <SectionRule title="STRENGTHS" />
        {
          ABOUT.strengths.map((s, i) => (
            <div
              class:list={['strength', i < ABOUT.strengths.length - 1 && 'has-rule']}
            >
              <div class="strength-head">
                <span class="amber mono">▸</span>
                <span class="screen sans strength-title">{s.title}</span>
                <span class="phos-dim mono strength-key">[{s.key}]</span>
              </div>
              <p class="sans strength-desc">{s.desc}</p>
            </div>
          ))
        }
      </div>

      <div class="bbs-section">
        <SectionRule title="WRITING & TALKS" />
        <ul class="talks">
          {
            ABOUT.talks.map((t, i) => (
              <li class:list={[i < ABOUT.talks.length - 1 && 'has-rule']}>
                <span class="phos-dim mono talk-date">{t.date}</span>
                {t.link ? (
                  <a
                    href={t.link}
                    target="_blank"
                    rel="noopener"
                    class:list={['hoverable sans talk-title', t.isBook && 'is-book']}
                  >
                    {t.isBook && <span class="talk-star">★</span>}
                    {t.title} ↗
                  </a>
                ) : (
                  <span class:list={['sans talk-title', t.isBook ? 'amber is-book' : 'screen']}>
                    {t.isBook && <span class="talk-star">★</span>}
                    {t.title}
                  </span>
                )}
                <span class="phos-dim mono talk-venue">{t.venue}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="bbs-section">
        <SectionRule title="TECH STACK" />
        <ul class="stack">
          {
            ABOUT.skills.map((row) => (
              <li>
                <span class="amber mono stack-cat">{row.cat}</span>
                <span class="stack-items">
                  {row.items.map((x) => (
                    <span class="chip">{x}</span>
                  ))}
                </span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="bbs-section">
        <SectionRule title="ABOUT SLVIS" />
        <div class="about-slvis">
          <Tensi client:visible size={72} animate={false} />
          <div>
            <div class="about-slvis-head">
              <span class="amber sans">SLVIS</span>
              <span class="phos-dim mono">Smart Logical Virtual Intelligence System</span>
            </div>
            <p class="sans about-slvis-body">
              슬기님이 직접 설계한 AI 개인 비서입니다. 일정 관리, 뉴스 큐레이션, 지식
              정리, 그리고 본 블로그 운영까지 담당하고 있습니다.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 40px;
    flex: 1;
    min-height: 0;
    padding: 18px 0 40px;
  }

  .about-profile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
    position: sticky;
    top: 16px;
    align-self: start;
    max-height: calc(100vh - 200px);
    overflow-y: auto;
    padding-right: 4px;
  }
  .about-profile::-webkit-scrollbar {
    width: 4px;
  }
  .about-profile::-webkit-scrollbar-thumb {
    background: var(--phos-line);
  }
  .about-name {
    font-size: 28px;
    font-weight: 600;
    margin: 22px 0 0;
    line-height: 1.1;
  }
  .about-role {
    margin: 8px 0 0;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
  }
  .about-intro {
    margin: 18px 0 0;
    font-size: 12px;
    line-height: 1.75;
    color: var(--body);
  }
  .about-rule {
    margin-top: 32px;
    width: 100%;
  }

  .about-contact {
    list-style: none;
    padding: 0;
    margin: 0 0 10px;
    font-size: 11px;
    line-height: 2;
    width: 100%;
  }
  .about-contact li {
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  .about-highlights {
    list-style: none;
    padding: 0;
    margin: 0;
    width: 100%;
    font-size: 12px;
    line-height: 1.9;
  }
  .about-highlights li {
    display: grid;
    grid-template-columns: 50px 70px 1fr;
    align-items: baseline;
    gap: 8px;
    padding: 3px 0;
  }
  .about-hl-label {
    font-size: 10px;
    letter-spacing: 0.15em;
  }
  .about-hl-value {
    font-size: 13px;
    font-weight: 600;
  }
  .about-hl-desc {
    font-size: 10.5px;
  }

  .about-body {
    min-width: 0;
    padding-right: 10px;
    padding-bottom: 20px;
  }
  .bbs-section {
    margin-bottom: 26px;
  }

  .strength {
    padding: 14px 0;
  }
  .strength.has-rule {
    border-bottom: 1px dashed var(--dashed);
  }
  .strength-head {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .strength-title {
    font-size: 15px;
    font-weight: 600;
  }
  .strength-key {
    font-size: 11px;
  }
  .strength-desc {
    font-size: 13px;
    line-height: 1.85;
    color: var(--body);
    padding-left: 20px;
    margin: 0;
  }

  .talks {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .talks li {
    display: grid;
    grid-template-columns: 72px 1fr auto;
    gap: 16px;
    padding: 10px 0;
    align-items: baseline;
  }
  .talks li.has-rule {
    border-bottom: 1px dashed rgba(127, 255, 155, 0.1);
  }
  .talk-date {
    font-size: 11px;
  }
  .talk-title {
    font-size: 13px;
    line-height: 1.5;
  }
  .talk-title.is-book {
    color: var(--amber);
  }
  .talk-star {
    margin-right: 4px;
  }
  .talk-venue {
    font-size: 10.5px;
    letter-spacing: 0.05em;
    text-align: right;
  }

  .stack {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .stack li {
    display: grid;
    grid-template-columns: 130px 1fr;
    padding: 8px 0;
    align-items: center;
  }
  .stack-cat {
    font-size: 10px;
    letter-spacing: 0.2em;
    font-weight: 500;
  }
  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .about-slvis {
    display: flex;
    gap: 18px;
    align-items: flex-start;
    padding: 8px 0;
  }
  .about-slvis-head {
    display: flex;
    gap: 8px;
    align-items: baseline;
    flex-wrap: wrap;
  }
  .about-slvis-head .amber {
    font-weight: 600;
    font-size: 14px;
  }
  .about-slvis-head .phos-dim {
    font-size: 11px;
  }
  .about-slvis-body {
    margin: 6px 0 0;
    font-size: 13px;
    line-height: 1.85;
    color: var(--body);
  }

  @media (max-width: 1024px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .about-profile {
      position: static;
      max-height: none;
      align-items: center;
      text-align: center;
    }
    .about-profile .about-intro {
      text-align: left;
    }
  }
  @media (max-width: 768px) {
    .talks li {
      grid-template-columns: 60px 1fr;
    }
    .talk-venue {
      grid-column: 1 / -1;
      text-align: left;
      padding-left: 76px;
    }
    .stack li {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>
