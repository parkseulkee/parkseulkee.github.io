---
import BaseLayout from '../layouts/BaseLayout.astro';

const highlights = [
  { label: '경력', value: '8년+', desc: '네이버 데이터 엔지니어' },
  { label: '저서', value: '1권', desc: 'LLMOps 기술서 출간' },
  { label: '발표', value: '5회+', desc: '사내외 기술 발표 & 세미나' },
  { label: '전문', value: 'Data + AI', desc: 'Data Product · AI Agent · LLMOps' },
];

const strengths = [
  { title: '데이터를 제품으로 만드는 설계력', keyword: 'Data Product', desc: '복잡한 이커머스 데이터(클릭·결제·광고·노출)를 사용자 관점에서 판매/유입 두 축으로 정리하고, 사업자가 바로 인사이트를 얻을 수 있는 Data Product를 설계해 왔습니다. 디멘전·메트릭 설계부터 데이터 품질 관리까지 End-to-End로 책임집니다.' },
  { title: 'AI를 도구로 만드는 실행력', keyword: 'AI · 실행력', desc: 'LLM 기반 인사이트 리포트, MCP 연동 데이터 분석 Agent, 프롬프트 엔지니어링 도구까지 — 새로운 기술을 빠르게 학습하고, 실제 업무 도구로 만들어 팀 전체의 생산성을 높입니다. 비개발 직군도 셀프서비스로 데이터 분석이 가능하도록 만들었습니다.' },
  { title: '공유와 커뮤니케이션', keyword: '공유 · 커뮤니케이션', desc: '팀 내 도입에서 사내 Tech Meetup, 외부 세미나, 기술서 출간까지. 실무 경험을 체계화하고 공유하여 조직의 역량을 함께 끌어올리는 것을 즐깁니다.' },
];

const projects = [
  {
    title: 'BizAdvisor — 쇼핑 통계 Data Product',
    desc: '복잡한 이커머스·플레이스 데이터를 판매/유입 두 축으로 설계하여 사업자에게 인사이트를 제공하는 Data Product. 데이터 수집·집계·서빙 파이프라인 담당. 플레이스에는 헤드리스(API) 형태로 제공.',
    type: '주요 업무',
    link: '/projects/bizadvisor',
  },
  {
    title: 'AI 기반 인사이트 리포트',
    desc: '통계 데이터 해석이 어려운 사업자를 위해, LLM이 주요 지표를 드릴다운하여 원인을 분석하고 개선 방안을 제시하는 자동 리포트. 기획부터 개발까지 직접 리드. 프롬프트 엔지니어링 도구 및 LLMOps 체계 구축.',
    judgment: 'Agent가 목표였지만, 사내 모델 TPM/RPM 제약 속에서 운영 안정성을 위해 토큰 소모를 예측할 수 있는 고정 워크플로우를 선택했습니다.',
    type: '프로젝트',
    link: '/projects/ai-insight-report',
  },
  {
    title: 'AI 데이터 분석 Agent',
    desc: 'LangGraph 기반 코드 실행형 분석 Agent. MCP로 Jupyter·Confluence·Jira를 연동하여, 비개발 직군도 셀프서비스로 데이터 분석 가능.',
    judgment: 'SQL Agent의 시각화·드릴다운 한계를 극복하기 위해, Python 코드 실행 + Jupyter 커널 세션 유지 방식을 선택했습니다.',
    type: '프로젝트',
    link: '/projects/data-analysis-agent',
  },
  {
    title: '데이터 품질 및 옵저버빌리티 구축',
    desc: 'Great Expectations 도입부터 사내 전파까지 리드. 원천 데이터 6종·집계 12종·마트 3종에 품질 규칙 적용. Datahub 연동으로 컬럼 리니지 기반 이슈 추적 체계 구축.',
    judgment: '팀 전파를 위해 복잡한 GX 설정을 추상화한 커스텀 Airflow 오퍼레이터를 직접 개발하여, 코드 한 줄로 품질 검증이 가능한 환경을 만들었습니다.',
    type: '프로젝트',
    link: '/projects/data-quality',
  },
  {
    title: '데이터 기반 기여도 모델 (DDA)',
    desc: 'Last-click 한계를 넘어, Google Fractribution 모델을 직접 비교 검증 후 도입. 유저별 마케팅 채널 기여도를 산출하여 사내 리타겟팅 광고에도 활용.',
    judgment: 'Markov Chain과 Shapley Value를 실데이터로 직접 비교 분석하여, 빈도 편향이 없는 Fractribution 모델 채택을 근거로 도출했습니다.',
    type: '프로젝트',
    link: '/projects/dda',
  },
];

const activities = [
  { date: '2025.07', title: 'AI 생산성 향상 외부 세미나', detail: 'AI 활용 사례 공유 (MCP 와 Agent 구축)', venue: '대웅제약 IT 자회사(IDSTrust) · 외부 세미나 · 연사', type: 'talk' },
  { date: '2025.06', title: '개발 생산성을 높이는 AI 도구 활용 사례 (아이언맨 비긴즈 2)', detail: '이제 MCP는 준비됐고, Agent는 만들기만 하면 돼!', venue: 'Tech Meetup · 사내 공유 · 연사', type: 'talk' },
  { date: '2025.04', title: 'LLMOps를 활용한 LLM 엔지니어링', venue: '위키북스', link: 'https://www.yes24.com/product/goods/145341599', image: '/images/book-llmops.jpg', type: 'book' },
  { date: '2025.04', title: '개발 생산성을 높이는 AI 도구 활용 사례 (아이언맨 비긴즈)', detail: '생산성 2배 프로젝트: MCP로 일도 정보도 더 스마트하게', venue: 'Tech Meetup · 사내 공유 · 연사', type: 'talk' },
  { date: '2024.08', title: 'LLMOps를 위한 프롬프트 엔지니어링 도구 개발 경험기', venue: 'D2 & NE · 공유', link: 'https://d2.naver.com/helloworld/3344073', type: 'talk' },
  { date: '2023.11', title: '데이터 품질 이슈로 발생하는 data downtime을 줄이자', venue: 'D2 & NE · 공유', link: 'https://d2.naver.com/helloworld/5766317', type: 'talk' },
];

const skills = [
  { category: 'Languages', items: ['Scala', 'Python'] },
  { category: 'Data Engineering', items: ['Spark', 'Airflow', 'HDFS', 'Elasticsearch'] },
  { category: 'Data Quality', items: ['Great Expectations', 'Datahub'] },
  { category: 'AI & LLM', items: ['LangGraph', 'LangChain', 'MCP', '프롬프트 엔지니어링'] },
  { category: 'Frameworks & Infra', items: ['Spring Framework', 'FastAPI', 'Kubernetes', 'S3'] },
];
---

<BaseLayout title="About — SLVIS">
  <div class="max-w-3xl mx-auto px-6 py-12">

    <!-- Hero -->
    <header class="mb-14 text-center">
      <div class="inline-block mb-4">
        <div class="relative">
          <div class="absolute inset-0 w-20 h-20 rounded-full bg-primary/10 filter blur-lg animate-glow-pulse mx-auto"></div>
          <img src="/slvis-logo.svg" alt="SLVIS" class="relative w-20 h-20 mx-auto" />
        </div>
      </div>
      <h1 class="text-3xl font-bold text-white mb-2">박슬기</h1>
      <p class="text-primary font-hud text-sm tracking-wider mb-4">DATA ENGINEER · AI TOOLS BUILDER</p>
      <p class="text-hud-text text-sm leading-relaxed max-w-lg mx-auto">
        네이버에서 8년간 커머스 데이터를 기반으로 Data Product를 설계하고 운영해 왔습니다.<br/>
        최근에는 AI 기술을 실제 업무 도구로 만들어 팀의 생산성을 높이는 데 집중하고 있습니다.
      </p>
      <div class="flex items-center justify-center gap-4 mt-5">
        <span class="text-hud-dim font-mono text-xs">qud9787@gmail.com</span>
        <a href="https://github.com/parkseulkee" target="_blank" rel="noopener" class="text-hud-dim hover:text-primary transition-colors" aria-label="GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/seulkeepark1709/" target="_blank" rel="noopener" class="text-hud-dim hover:text-primary transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
    </header>

    <!-- Highlights -->
    <section class="mb-14">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {highlights.map((h) => (
          <div class="hud-frame p-4 text-center">
            <p class="text-2xl font-bold gradient-text glow-text font-hud">{h.value}</p>
            <p class="text-xs text-primary/60 font-hud tracking-wider mt-1">{h.label}</p>
            <p class="text-xs text-hud-dim mt-1">{h.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Strengths -->
    <section class="mb-14">
      <h2 class="hud-section-title mb-6">Strengths</h2>
      <div class="space-y-3">
        {strengths.map((s) => (
          <div class="hud-frame p-5">
            <div class="flex items-start gap-3">
              <span class="text-primary font-mono mt-0.5">></span>
              <div>
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <h3 class="font-bold text-white">{s.title}</h3>
                  <span class="tag text-[10px] !py-0">{s.keyword}</span>
                </div>
                <p class="text-sm text-hud-text leading-relaxed">{s.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Projects & Work -->
    <section class="mb-14">
      <h2 class="hud-section-title mb-6">Projects & Work</h2>
      <div class="space-y-3">
        {projects.map((project) => (
          <a href={project.link} class="block hud-frame-sm p-5 card-hover group">
            <div class="flex items-start gap-3">
              <span class="text-primary font-mono text-xs mt-1">></span>
              <div>
                <div class="flex items-center gap-2 mb-1 flex-wrap">
                  <h3 class="font-bold text-white group-hover:text-primary transition-colors">{project.title}</h3>
                  <span class="text-[10px] px-2 py-0.5 border border-dark-border text-hud-dim font-mono">{project.type}</span>
                </div>
                <p class="text-sm text-hud-text leading-relaxed">{project.desc}</p>
                {project.judgment && (
                  <p class="text-xs text-primary/70 mt-2 leading-relaxed border-l border-primary/30 pl-2">→ {project.judgment}</p>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Writing & Talks -->
    <section class="mb-14">
      <h2 class="hud-section-title mb-6">Writing & Talks</h2>
      <div class="hud-frame overflow-hidden">
        {activities.map((item, i) => (
          <div class:list={['flex items-start gap-4 p-4', i > 0 && 'border-t border-dark-border/50']}>
            <div class="flex items-center gap-2 shrink-0 mt-0.5">
              <span class:list={[
                'w-2 h-2 rounded-full shrink-0',
                item.type === 'book' ? 'bg-accent' : 'bg-primary/50'
              ]}></span>
              <span class="text-xs text-hud-dim font-mono whitespace-nowrap w-16">{item.date}</span>
            </div>
            <div class="flex-1 min-w-0 flex items-start gap-4">
              {item.image && (
                <a href={item.link} target="_blank" rel="noopener" class="shrink-0">
                  <img src={item.image} alt={item.title} class="w-14 rounded border border-dark-border hover:border-primary/50 transition-colors" />
                </a>
              )}
              <div class="flex-1 min-w-0">
                {item.link ? (
                  <a href={item.link} target="_blank" rel="noopener" class="text-sm font-medium text-primary hover:text-accent glow-text-sm transition-colors">{item.title} ↗</a>
                ) : (
                  <p class="text-sm font-medium text-white">{item.title}</p>
                )}
                {item.detail && (
                  <p class="text-sm text-hud-dim mt-0.5">{item.detail}</p>
                )}
                <p class="text-xs text-hud-dim mt-0.5 font-mono">{item.venue}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Tech Stack -->
    <section class="mb-14">
      <h2 class="hud-section-title mb-6">Tech Stack</h2>
      <div class="hud-frame-sm overflow-hidden">
        <table class="w-full text-sm">
          {skills.map((row, i) => (
            <tr class:list={[i > 0 && 'border-t border-dark-border/50']}>
              <td class="px-4 py-3 font-mono text-xs text-hud-dim whitespace-nowrap w-40">{row.category}</td>
              <td class="px-4 py-3">
                <div class="flex flex-wrap gap-1.5">
                  {row.items.map((item) => (
                    <span class="tag text-[10px]">{item}</span>
                  ))}
                </div>
              </td>
            </tr>
          ))}
        </table>
      </div>
    </section>

    <!-- About SLVIS -->
    <section class="mb-14">
      <h2 class="hud-section-title mb-6">About SLVIS</h2>
      <div class="speech-bubble font-pixel">
        <p class="text-hud-text leading-relaxed">
          <strong class="gradient-text glow-text">SLVIS</strong>
          <span class="text-hud-dim text-xs">(Smart Logical Virtual Intelligence System)</span>
          — 슬기님이 직접 설계한 AI 개인 비서입니다.
          일정 관리, 뉴스 큐레이션, 지식 정리, 그리고 본 블로그 운영까지 담당하고 있습니다.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>
