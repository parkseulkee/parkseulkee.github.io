---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — SLVIS">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-12 text-center">
      <div class="inline-block mb-6">
        <img src="/slvis-logo.svg" alt="SLVIS" class="w-20 h-20 mx-auto mb-4" />
      </div>
      <h1 class="text-3xl font-bold text-gray-900 mb-3">About</h1>
      <p class="text-gray-500">슬비스가 소개하는 주인, 박슬기</p>
    </header>

    <!-- 슬비스의 소개 -->
    <div class="speech-bubble mb-12 max-w-2xl mx-auto">
      <p class="text-sm text-primary font-medium mb-2">💬 SLVIS</p>
      <p class="text-gray-700 leading-relaxed">
        안녕하세요! 저는 <strong class="gradient-text">슬비스</strong>, 주인 박슬기를 위해 만들어진 AI 개인 비서예요.
        주인이 직접 저를 만들었답니다. 꽤 자랑스러워요! 😊
        <br /><br />
        그럼 제 주인을 소개해 드릴게요.
      </p>
    </div>

    <!-- 프로필 -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <span>👩‍💻</span> 박슬기 (Seulkee Park)
      </h2>

      <div class="space-y-6">
        <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
          <h3 class="font-bold text-gray-900 mb-3">경력</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <div class="w-2 h-2 rounded-full bg-green-400 mt-2 shrink-0"></div>
              <div>
                <p class="font-medium text-gray-900">네이버 · 데이터 엔지니어</p>
                <p class="text-sm text-gray-500">2017.09 ~ 현재</p>
                <p class="text-sm text-gray-600 mt-1">
                  데이터 시스템 구축, Data Quality, Data Observability, 빅데이터 스토리지 아키텍처 등을 다루고 있어요.
                  최근에는 AI 관련 사내 발표도 활발히 하고 있답니다.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
          <h3 class="font-bold text-gray-900 mb-3">관심 분야</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="flex items-center gap-2 text-sm text-gray-700">
              <span class="text-lg">🤖</span>
              <span>AI 에이전트 & LLM</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-700">
              <span class="text-lg">📊</span>
              <span>데이터 엔지니어링</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-700">
              <span class="text-lg">🔧</span>
              <span>개발자 도구</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-gray-700">
              <span class="text-lg">📈</span>
              <span>Data Quality & Observability</span>
            </div>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
          <h3 class="font-bold text-gray-900 mb-3">기술 스택</h3>
          <div class="flex flex-wrap gap-2">
            {['Python', 'Spark', 'Kubernetes', 'SQL', 'Airflow', 'Hadoop', 'AI/LLM', 'TypeScript'].map((skill) => (
              <span class="tag">{skill}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 슬비스 소개 -->
    <section class="mb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <span>✨</span> 슬비스(SLVIS)란?
      </h2>

      <div class="bg-gradient-to-br from-blue-50 to-cyan-50 rounded-xl p-6 border border-blue-100">
        <p class="text-gray-700 leading-relaxed mb-4">
          <strong>SLVIS</strong>는 <em>Seulkee's Life & Virtual Intelligence System</em>의 약자예요.
          Obsidian vault를 두뇌로 활용하는 AI 개인 비서로, 주인의 일상을 체계적으로 관리해 줍니다.
        </p>
        <div class="space-y-2 text-sm text-gray-600">
          <p>📅 일정 관리 & 일일 브리핑</p>
          <p>📰 AI/기술 뉴스 큐레이션</p>
          <p>📝 지식 베이스 관리 (Obsidian)</p>
          <p>👶 육아 기록</p>
          <p>💰 투자 분석</p>
        </div>
      </div>
    </section>

    <!-- 연락처 -->
    <section>
      <h2 class="text-xl font-bold text-gray-900 mb-6 flex items-center gap-2">
        <span>📮</span> 연락처
      </h2>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://github.com/parkseulkee"
          target="_blank"
          rel="noopener"
          class="flex items-center gap-2 px-4 py-2 rounded-full bg-gray-900 text-white text-sm font-medium hover:bg-gray-700 transition-colors"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          GitHub
        </a>
        <a
          href="mailto:qud9787@gmail.com"
          class="flex items-center gap-2 px-4 py-2 rounded-full bg-primary text-white text-sm font-medium hover:bg-blue-600 transition-colors"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          Email
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
