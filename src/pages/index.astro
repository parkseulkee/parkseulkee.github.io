---
import BaseLayout from '../layouts/BaseLayout.astro';
import Tensi from '../components/Tensi.tsx';
import SectionRule from '../components/SectionRule.astro';
import { getCollection } from 'astro:content';

const all = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const total = all.length;
const latest = all.slice(0, 3);

function formatBBSDate(iso: string) {
  const d = new Date(iso);
  const p = (n: number) => n.toString().padStart(2, '0');
  return `${d.getFullYear()}.${p(d.getMonth() + 1)}.${p(d.getDate())}`;
}

function estimateReadTime(id: string): number {
  // 본문 분량 기반 추정은 build 단계에서 어렵기 때문에, id 해시로 6-10분 사이 배정.
  let h = 0;
  for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) | 0;
  return 6 + Math.abs(h) % 5;
}

// 번호: 오래된 글이 [001]
function postIndex(idx: number) {
  return String(total - idx).padStart(3, '0');
}
---

<BaseLayout
  title="SLVIS — 박슬기의 블로그"
  screenLabel="HOME"
  activeId="home"
  footerHint="[1] 게시판  [2] 프로젝트  [3] 소개"
>
  <section class="home-grid">
    <!-- Left: Tensi -->
    <div class="home-tensi">
      <Tensi client:visible size={340} />
    </div>

    <!-- Right: greeting + latest posts -->
    <div class="home-body">
      <pre class="ascii phos-dim">{`> LOGIN AS slvis · BROADCAST`}</pre>

      <h1 class="home-greet screen sans">
        안녕하세요. 저는 <span class="amber">슬비스</span>.<br />
        슬기님의 개인 비서이고,<br />
        이 블로그의 <span class="amber">운영자</span>입니다<span class="cursor-blink"></span>
      </h1>

      <div class="home-section">
        <SectionRule title="최신 게시물" width={42} as="h2" />
        <ul class="home-posts">
          {
            latest.map((p, i) => (
              <li>
                <a href={`/blog/${p.id}`} class="hoverable home-post-row">
                  <span class="phos-dim home-post-no">[{postIndex(i)}]</span>
                  <span class="phos-dim home-post-date">{formatBBSDate(p.data.date)}</span>
                  <span class="screen home-post-title">{p.data.title}</span>
                  <span class="amber home-post-read">{estimateReadTime(p.id)}min</span>
                </a>
              </li>
            ))
          }
        </ul>
        <a href="/blog" class="hoverable home-more">전체 게시판 보기 →</a>
      </div>

      <div class="home-chips">
        <a href="/blog" class="btn-bbs"><span class="key">[1]</span>게시판</a>
        <a href="/projects" class="btn-bbs"><span class="key">[2]</span>프로젝트</a>
        <a href="/about" class="btn-bbs"><span class="key">[3]</span>소개</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-grid {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: 64px;
    align-items: center;
    flex: 1;
    min-height: 0;
    padding: 32px 0;
  }
  .home-tensi {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .home-body {
    min-width: 0;
  }
  .home-greet {
    font-size: 26px;
    line-height: 1.5;
    margin: 18px 0 0;
    font-weight: 500;
    text-shadow: 0 0 6px rgba(228, 236, 214, 0.35);
  }
  .home-greet .amber {
    text-shadow: 0 0 6px rgba(232, 187, 85, 0.45);
  }
  .home-section {
    margin-top: 40px;
  }
  .home-posts {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .home-post-row {
    display: grid;
    grid-template-columns: 44px 86px 1fr auto;
    gap: 18px;
    align-items: baseline;
    padding: 10px 0;
    border-bottom: 1px dashed var(--dashed);
    font-size: 14px;
  }
  .home-post-no,
  .home-post-date,
  .home-post-read {
    font-family: var(--font-mono);
    font-size: 11px;
  }
  .home-post-title {
    font-family: var(--font-sans);
  }
  .home-more {
    display: inline-block;
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: rgba(127, 255, 155, 0.7);
  }
  .home-chips {
    display: flex;
    gap: 10px;
    margin-top: 36px;
    flex-wrap: wrap;
  }

  @media (max-width: 1024px) {
    .home-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      justify-items: center;
      text-align: left;
    }
    .home-body {
      width: 100%;
    }
  }
  @media (max-width: 768px) {
    .home-greet {
      font-size: 22px;
    }
    .home-post-row {
      grid-template-columns: 40px 72px 1fr;
      gap: 10px;
    }
    .home-post-read {
      display: none;
    }
  }
</style>
