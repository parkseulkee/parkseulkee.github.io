---
import BaseLayout from '../layouts/BaseLayout.astro';

const opensourceProjects = [
  {
    title: 'parkseulkee.github.io',
    description: '슬비스가 운영하는 개인 블로그 & 포트폴리오. Astro + Tailwind CSS 기반의 HUD 스타일 디자인.',
    tech: ['Astro', 'Tailwind CSS', 'TypeScript'],
    link: 'https://github.com/parkseulkee/parkseulkee.github.io',
    highlight: false,
    external: true,
  },
  {
    title: 'LLMOps를 활용한 LLM 엔지니어링',
    description: 'LLM 애플리케이션의 개발, 운영, 평가, 개선 전 과정을 다루는 실무 가이드. LangChain, Streamlit, Pinecone 등의 도구를 활용한 LLMOps 실전서.',
    tech: ['LangChain', 'Streamlit', 'Pinecone', 'Python'],
    link: 'https://github.com/parkseulkee/llmops',
    highlight: true,
    external: true,
  },
];

const internalProjects = [
  {
    title: 'BizAdvisor — 쇼핑 통계 Data Product',
    description: '복잡한 이커머스·플레이스 데이터를 판매/유입 두 축으로 설계하여 사업자에게 인사이트를 제공하는 Data Product. 데이터 수집·집계·서빙 파이프라인 담당.',
    tech: ['Spark', 'Elasticsearch', 'Airflow', 'Java', 'Spring', 'S3'],
    link: '/projects/bizadvisor',
  },
  {
    title: 'AI 기반 인사이트 리포트',
    description: 'LLM이 주요 지표를 드릴다운하여 원인 분석과 개선 방안을 제시하는 자동 리포트. 기획부터 개발까지 직접 리드. 프롬프트 엔지니어링 도구 및 LLMOps 체계 구축.',
    tech: ['LangChain', 'Langfuse', 'Streamlit'],
    link: '/projects/ai-insight-report',
  },
  {
    title: 'AI 데이터 분석 Agent',
    description: 'LangGraph 기반 코드 실행형 분석 Agent. MCP로 Jupyter·Confluence·Jira 연동. 비개발 직군도 셀프서비스 분석 가능.',
    tech: ['LangGraph', 'MCP', 'Python', 'Jupyter'],
    link: '/projects/data-analysis-agent',
  },
  {
    title: '데이터 품질 및 옵저버빌리티 구축',
    description: '원천 6종·집계 12종·마트 3종에 품질 규칙 적용. Datahub 연동으로 컬럼 리니지 기반 이슈 추적 체계 구축.',
    tech: ['Great Expectations', 'Airflow', 'Datahub'],
    link: '/projects/data-quality',
  },
  {
    title: '데이터 기반 기여도 모델 (DDA)',
    description: 'Last-click 한계를 넘어 Google Fractribution 모델을 직접 비교 검증 후 도입. 사내 리타겟팅 광고에도 활용.',
    tech: ['Spark', 'Python', 'SQL'],
    link: '/projects/dda',
  },
];
---

<BaseLayout title="Projects — SLVIS">
  <div class="max-w-3xl mx-auto px-6 py-12">
    <header class="mb-12">
      <h1 class="text-3xl font-bold text-white mb-3 font-hud tracking-wide">Projects</h1>
      <p class="text-hud-dim font-mono text-sm">슬기님이 만들고 있는 것들을 소개해 드릴게요</p>
    </header>

    <!-- Open Source -->
    <section class="mb-16">
      <h2 class="hud-section-title mb-6">Open Source</h2>
      <div class="space-y-3">
        {opensourceProjects.map((project) => (
          <a
            href={project.link}
            target="_blank"
            rel="noopener"
            class="block hud-frame-sm p-5 card-hover group"
          >
            <div class="flex items-start gap-3">
              <div class="flex-1">
                <h3 class="font-bold text-white group-hover:text-primary transition-colors mb-1">
                  {project.title}
                  <svg class="w-4 h-4 inline-block ml-1 opacity-0 group-hover:opacity-100 transition-opacity text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                  </svg>
                </h3>
                <p class="text-hud-text text-sm mb-2">{project.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.map((t) => (
                    <span class="tag text-[10px]">{t}</span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Company Projects -->
    <section>
      <h2 class="hud-section-title mb-6">Company Projects · Naver</h2>
      <div class="space-y-3">
        {internalProjects.map((project) => (
          <a
            href={project.link}
            class="block hud-frame-sm p-5 card-hover group"
          >
            <div class="flex items-start gap-3">
              <div class="flex-1">
                <h3 class="font-bold text-white group-hover:text-primary transition-colors mb-1">{project.title}</h3>
                <p class="text-hud-text text-sm mb-2">{project.description}</p>
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.map((t) => (
                    <span class="tag text-[10px]">{t}</span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
